{
  "pages": {
    "/layout": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/css/app/layout.css",
      "static/chunks/app/layout.js"
    ],
    "/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/page.js"
    ],
    "/login/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/login/page.js"
    ],
    "/api/auth/[...nextauth]/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/api/auth/[...nextauth]/route.js"
    ],
    "/(dashboard)/dashboard/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(dashboard)/dashboard/page.js"
    ],
    "/(dashboard)/pendentes/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(dashboard)/pendentes/page.js"
    ],
    "/(dashboard)/solicitacoes/[id]/page": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/(dashboard)/solicitacoes/[id]/page.js"
    ],
    "/api/purchase-requests/[id]/approve/route": [
      "static/chunks/webpack.js",
      "static/chunks/main-app.js",
      "static/chunks/app/api/purchase-requests/[id]/approve/route.js"
    ]
  }
}